{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowJs": true,
    "noImplicitAny": true,
    "lib": ["esnext", "dom"],
    "types": ["vite/client", "node"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/render/*"]
    }
  },
  "include": [
    "src/render/**/*.ts",
    "src/render/**/*.d.ts",
    "src/render/**/*.tsx",
    "src/render/**/*.vue"
  ],
  "exclude": ["node_modules"]
}
