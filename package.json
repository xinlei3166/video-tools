{
  "name": "video-tools",
  "version": "1.0.0",
  "description": "用 electron 和 ffmpeg 做的一个视频转换工具，m3u8转换为mp4并下载到本地。",
  "keywords": [
    "electron",
    "ffmpeg",
    "m3u8",
    "mp4",
    "video"
  ],
  "homepage": "https://github.com/xinlei3166/video-tools",
  "bugs": {
    "url": "https://github.com/xinlei3166/video-tools/issues"
  },
  "author": "junxi",
  "repository": {
    "type": "git",
    "url": "https://github.com/xinlei3166/video-tools"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "simple-git-hooks",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "dev": "vite --host",
    "build": "vite build",
    "serve": "vite preview",
    "clean": "rm -rf dist/main dist/render",
    "dev:electron": "cross-env NODE_ENV=development TSX_TSCONFIG_PATH=./tsconfig.electron.json electron index.js",
    "tsc:electron": "tsc -p tsconfig.electron.json",
    "build:electron-win": "pnpm tsc:electron && electron-builder --win --x64",
    "build:electron-mac": "pnpm tsc:electron && electron-builder --mac",
    "build:win": "run-s clean build build:electron-win",
    "build:mac": "run-s clean build build:electron-mac"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@vueuse/components": "^14.2.1",
    "@vueuse/core": "^14.2.1",
    "animate.css": "^4.1.1",
    "axios": "^1.15.0",
    "cos-js-sdk-v5": "^1.10.1",
    "dayjs": "^1.11.20",
    "fluent-ffmpeg": "^2.1.3",
    "js-audio-recorder": "^1.0.7",
    "js-cookie": "^3.0.5",
    "mitt": "^3.0.1",
    "nanoid": "^3.3.11",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "qs": "^6.15.1",
    "sortablejs": "^1.15.7",
    "tdesign-icons-vue-next": "^0.4.4",
    "tdesign-vue-next": "^1.19.1",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tdesign-vue-next/auto-import-resolver": "^0.1.6",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/js-cookie": "^3.0.6",
    "@types/mockjs": "^1.0.10",
    "@types/node": "^25.6.0",
    "@types/nprogress": "^0.2.3",
    "@types/qs": "^6.15.0",
    "@types/verror": "latest",
    "@unocss/postcss": "^66.6.8",
    "@unocss/preset-rem-to-px": "^66.6.8",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/compiler-sfc": "^3.5.32",
    "@yunquejs/release": "^0.1.9",
    "conventional-changelog-cli": "^5.0.0",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "less": "^4.6.4",
    "less-loader": "^12.3.2",
    "lint-staged": "^16.4.0",
    "mockjs": "^1.1.0",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "picocolors": "latest",
    "postcss": "^8.5.9",
    "simple-git-hooks": "latest",
    "tsx": "latest",
    "typescript": "^6.0.2",
    "unocss": "^66.6.8",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.8"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged --concurrent false",
    "commit-msg": "pnpm exec tsx scripts/verifyCommit.ts $1"
  },
  "lint-staged": {
    "*": [
      "oxlint --fix --no-error-on-unmatched-pattern",
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": []
    },
    "onlyBuiltDependencies": [
      "@ffmpeg-installer/darwin-arm64",
      "@ffprobe-installer/darwin-arm64",
      "core-js",
      "cos-js-sdk-v5",
      "electron",
      "esbuild",
      "simple-git-hooks",
      "vue-demi"
    ]
  },
  "build": {
    "asar": true,
    "asarUnpack": [
      "node_modules/@ffmpeg-installer"
    ],
    "appId": "video-tools",
    "productName": "视频转换工具",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "files": [
      "dist/main/**/*",
      "dist/render/**/*"
    ],
    "directories": {
      "output": "dist/release"
    }
  }
}
